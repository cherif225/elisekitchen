# ================================================
# ELISE KITCHEN — Variables d'environnement
# Copiez ce fichier en .env et personnalisez-le
# ================================================

# Clé secrète Flask (CHANGEZ OBLIGATOIREMENT en production !)
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire-ici

# Chemin de la base SQLite (optionnel, default: instance/chegest.db)
# DATABASE_PATH=/var/www/elisekitchen/instance/chegest.db

# Port d'écoute (utilisé par Railway/Heroku via $PORT)
PORT=5000

# Mode debug (toujours False en production !)
FLASK_DEBUG=0
FLASK_ENV=production
